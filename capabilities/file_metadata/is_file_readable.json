{
  "type": "function",
  "function": {
    "name": "is_file_readable",
    "description": "Check if a file is readable.",
    "long_description": "Determines whether the current user has read permission for a file.",
    "domain": "File Metadata",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the file"
        }
      },
      "required": [
        "path"
      ]
    },
    "example_user_queries": [
      "Is ./README.md readable?",
      "Check whether ./capabilities/travel/get_flight_status.json can be read.",
      "Tell me if ./capabilities/map/get_route_distance.json is readable.",
      "Can the file ./capabilities/news/get_trending_topics.json be read?",
      "Verify read access for ./capabilities/stock/get_dividend_info.json.",
      "Is ./capabilities/time_operations/add_hours.json readable by the current user?",
      "Check if ./capabilities/health/calculate_bmi.json has read permission.",
      "Find out whether ./capabilities/maths/percentage_calc.json is readable.",
      "Do I have read access to ./capabilities/file_metadata/get_file_permissions.json?",
      "Confirm that ./capabilities/ir/search_recent_documents.json is readable."
    ]
  }
}
