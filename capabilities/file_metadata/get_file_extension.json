{
  "type": "function",
  "function": {
    "name": "get_file_extension",
    "description": "Get the file extension from a path.",
    "long_description": "Extracts and returns the file extension and filename components.",
    "domain": "File Metadata",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the file"
        }
      },
      "required": [
        "path"
      ]
    },
    "example_user_queries": [
      "What is the file extension of ./README.md?",
      "Get the extension for ./capabilities/travel/get_distance_between_cities.json.",
      "Tell me the extension of /tmp/archive.tar.gz.",
      "Find the file extension for ./capabilities/news/get_trending_topics.json.",
      "Show the extension of ./capabilities/map/get_route_distance.json.",
      "What extension does ./capabilities/stock/compare_stocks.json use?",
      "Check the extension on ./capabilities/time_operations/convert_to_24_hour.json.",
      "Return the file extension for ./capabilities/maths/percentage_calc.json.",
      "Identify the extension of ./capabilities/health/estimate_daily_calories.json.",
      "Give me the extension for ./capabilities/ir/keyword_search.json."
    ]
  }
}
