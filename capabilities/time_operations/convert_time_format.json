          "description": "Input time format (default: %H:%M:%S)"
        },
        "output_format": {
          "type": "string",
          "description": "Output time format (default: %I:%M:%S %p)"
        }
      },
      "required": [
        "time_string"
      ]
    },
    "example_user_queries": [
